OPERATOR_KEY=<PRIVATE_KEY>
OPERATOR_ID=<ACCOUNT_ID>
# Network name passed to Client::forName().
# Accepted values: mainnet | testnet | previewnet | localhost
HIERO_NETWORK=<NETWORK_NAME>
CONFIG_FILE=<PATH_TO_CLIENT_CONFIG>
PASSPHRASE=<OPTIONAL_PASSWORD_FOR_MNEMONIC_GENERATION>
# Mirror-node endpoint used by InitializeClientWithMirrorNodeAddressBookExample.
# For a local solo node use: 127.0.0.1:5600
MIRROR_NODE=<MIRROR_NODE_ENDPOINT>
